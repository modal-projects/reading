---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const spikes = (await getCollection("spikes")).sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime()
);
const featured = spikes.slice(0, 2);
---

<BaseLayout title="Reading | Modal">
  <section class="landing-hero">
    <p class="eyebrow">Modal · reading</p>
    <h1>A reading room for the systems we care about.</h1>
    <p class="hero-summary">
      Short, opinionated spikes on training, inference, and platform topics that come up at Modal.
      Each one is a concise overview, an annotated reading list, and mirrored PDFs when they are
      worth keeping close.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="/spikes/">Browse spikes</a>
      <a class="button" href="https://github.com/modal-projects/reading#add-a-paper" target="_blank" rel="noreferrer">Add a paper</a>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>Recent spikes</h2>
    </div>
    <div class="card-grid">
      {featured.map((entry) => (
        <a class="spike-card" href={`/spikes/${entry.slug}/`}>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.summary}</p>
          <div class="card-footer">
            <span>{entry.data.sourceCount} sources</span>
            <span>{entry.data.updatedAt.toISOString().slice(0, 10)}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
