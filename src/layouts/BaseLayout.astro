---
interface Props {
  title: string;
  description?: string;
}

import "../styles/global.css";

const { title, description = "Agent-native reading spikes for team research." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-mark" href="/">Reading</a>
        <nav class="site-nav">
          <a href="/spikes/">Spikes</a>
        </nav>
      </header>
      <main class="page-main">
        <slot />
      </main>
    </div>
  </body>
</html>
