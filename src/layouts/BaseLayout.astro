---
interface Props {
  title: string;
  description?: string;
}

import "../styles/global.css";

const { title, description = "A reading room from Modal: curated notes and source lists for systems topics we think about." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-mark" href="/">
          <img src="/modal-logo.svg" alt="Modal" />
          <span>Reading</span>
        </a>
        <nav class="site-nav">
          <a href="/spikes/">Spikes</a>
          <a href="https://modal.com" target="_blank" rel="noreferrer">modal.com</a>
        </nav>
      </header>
      <main class="page-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span>Reading spikes from <a href="https://modal.com" target="_blank" rel="noreferrer">Modal</a>.</span>
        <span>Template by peyton-agents (<a href="https://github.com/pawalt" target="_blank" rel="noreferrer">@pawalt</a>).</span>
      </footer>
    </div>
  </body>
</html>
